{
    "name": "coffez-ch",
    "private": true,
    "engines": {
        "node": "22"
    },
    "volta": {
        "node": "22.22.3"
    },
    "scripts": {
        "predev": "mkdir -p .tmp",
        "dev": "TMPDIR=$PWD/.tmp nuxt dev --clear",
        "build": "nuxt build",
        "postinstall": "nuxt prepare",
        "functions": "cd functions && npm i && npm run build && cd ..",
        "deploy": "npm run build && npm run functions && firebase deploy",
        "test": "npx vitest run",
        "test:coverage": "npx vitest run --coverage",
        "test:watch": "npx vitest watch",
        "test:ui": "npx vitest --ui",
        "test:e2e": "npx playwright test",
        "test:e2e:headed": "npx playwright test --headed",
        "test:e2e:ui": "npx playwright test --ui"
    },
    "devDependencies": {
        "@nuxtjs/i18n": "^10.4.0",
        "@nuxtjs/tailwindcss": "^6.14.0",
        "@playwright/test": "^1.58.0",
        "@types/file-saver": "^2.0.7",
        "@types/minimasonry": "^1.3.5",
        "@types/node": "^22.15.3",
        "@vitejs/plugin-vue": "^6.0.3",
        "@vitest/coverage-v8": "^4.0.18",
        "@vitest/ui": "^4.0.18",
        "firebase-admin": "^13.10.0",
        "firebase-functions": "^7.2.5",
        "happy-dom": "^20.3.9",
        "jsdom": "^27.4.0",
        "typescript": "^5.8.3",
        "vitest": "^4.0.18"
    },
    "dependencies": {
        "@vueuse/components": "^13.1.0",
        "@vueuse/core": "^13.1.0",
        "@vueuse/firebase": "^13.1.0",
        "axios": "^1.9.0",
        "date-fns": "^4.1.0",
        "file-saver": "^2.0.5",
        "firebase": "^11.6.1",
        "jszip": "^3.10.1",
        "minimasonry": "^1.3.2",
        "nuxt": "^4.4.7",
        "sharp": "^0.34.3"
    }
}
