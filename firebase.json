{
    "functions": {
        "source": "functions",
        "codebase": "default",
        "runtime": "nodejs22",
        "ignore": [
            "node_modules",
            ".git",
            "firebase-debug.log",
            "firebase-debug.*.log",
            ".env"
        ],
        "predeploy": [
            "npm --prefix \"$RESOURCE_DIR\" ci",
            "npm --prefix \"$RESOURCE_DIR\" run build"
        ]
    },
    "firestore": {
        "rules": "firestore.rules",
        "indexes": "firestore.indexes.json"
    },
    "emulators": {
        "functions": {
            "port": 5001
        },
        "ui": {
            "enabled": true
        },
        "singleProjectMode": true,
        "firestore": {
            "port": 8080
        }
    }
}
