rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.admin == true;
    }

    // Helper function to check if user owns the data
    function isOwner() {
      return request.auth != null && 
             request.auth.uid == resource.data.uid;
    }

    // Helper function for data validation
    function isValidEventData() {
      return request.method == 'get' ||
             (request.resource.data.title is string &&
              request.resource.data.startDate is timestamp &&
              request.resource.data.endDate is timestamp);
    }

    function isValidPortraitData() {
      return request.method == 'get' ||
             (request.resource.data.name is string &&
              request.resource.data.createdDate is timestamp &&
              (request.resource.data.imageUrl is string || request.resource.data.urlFirebaseOriginal is string));
    }

    // ==========================================
    // EVENTS COLLECTION - Anyone can read, only admin can write
    // ==========================================
    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin() && isValidEventData();
    }

    // ==========================================
    // GALLERY COLLECTION - Anyone can read, only admin can write
    // ==========================================
    match /gallery/{galleryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ==========================================
    // PORTRAITS COLLECTION - Anyone can read, only admin can write
    // ==========================================
    match /portraits/{portraitId} {
      allow read: if true;
      allow write: if isAdmin() && isValidPortraitData();
    }

    // ==========================================
    // PRINT QUEUE - Only admin can read/write
    // ==========================================
    match /printQueue/{documentId} {
      allow read, write: if isAdmin();
    }

    // ==========================================
    // SETTINGS - Only admin can read/write
    // ==========================================
    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }

    // ==========================================
    // DEFAULT RULE - Deny all other access
    // ==========================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}